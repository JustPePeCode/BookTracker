{
  "ConnectionStrings": {
    "BookTracker": "Data Source=book-tracker.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
